@startuml
!pragma layout smetana
title Plataforma Web FST\nPaquete 4 - Resultados y reportes
left to right direction
skinparam packageStyle rectangle
skinparam actorStyle awesome
skinparam usecase {
  BackgroundColor White
  BorderColor DarkSlateGray
}
actor "Investigador" as INV
rectangle "Plataforma Web FST - Paquete 4" {
  usecase "Consultar resultados por especimen" as UC41
  usecase "Desglosar por minuto\nconductas/min por animal" as UC42
  usecase "Comparar Dia 1 vs Dia 2\nbarras de distribucion por animal" as UC43
  usecase "Descargar reporte PDF" as UC45
  usecase "Generar archivo de reporte\nconservado indefinidamente en servidor" as UC46
}
INV --> UC41
INV --> UC45
UC42 ..> UC41 : <<extend>>\n[solicita desglose]
UC43 ..> UC41 : <<extend>>\n[ambos videos procesados]
UC45 ..> UC46 : <<include>>
@enduml
